# Model Inference Provider Configuration
# Set either AIML_API_KEY or OPENROUTER_API_KEY depending on your preferred provider
AIML_API_KEY=your_aiml_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
MODEL_NAME=anthropic/claude-3.5-sonnet

# Band Platform Configuration (Thenvoi SDK)
# Obtain these from the Band Developer Console (app.thenvoi.com / band.ai)
BAND_API_KEY=your_band_api_key_here
BAND_AGENT_ID=your_band_agent_id_here

# Pipeline Settings
PIPELINE_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
