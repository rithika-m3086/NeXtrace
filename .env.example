# ──────────────────────────────────────────────────────────────────────────
# Model Inference Provider Configuration
# ──────────────────────────────────────────────────────────────────────────
# NeXtrace routes all agent reasoning through AI/ML API (partner provider).
# Get your key at https://aimlapi.com  →  redeem the hackathon coupon for credits.
AIML_API_KEY=your_aiml_api_key_here

# Optional fallback provider (no partner-prize eligibility).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Partner provider for Featherless API
FEATHERLESS_API_KEY=your_featherless_api_key_here

# Model identifier as exposed by the active provider.
MODEL_NAME=anthropic/claude-3.5-sonnet

# Per-agent Model / Provider Configuration (optional overrides)
# Providers: aiml | featherless | openrouter
AGENT1_PROVIDER=featherless
AGENT1_MODEL=meta-llama/llama-3-70b-instruct
AGENT2_PROVIDER=aiml
AGENT2_MODEL=meta-llama/llama-3-70b-instruct
AGENT3_PROVIDER=aiml
AGENT3_MODEL=meta-llama/llama-3-70b-instruct
AGENT4_PROVIDER=aiml
AGENT4_MODEL=anthropic/claude-3.5-sonnet


# ──────────────────────────────────────────────────────────────────────────
# Band Platform Configuration (band-sdk)
# ──────────────────────────────────────────────────────────────────────────
# Each agent is registered separately in Band and receives its own API key +
# agent UUID. All four agents join ONE shared chat room and hand off work by
# @mentioning the next agent. Create agents/room at https://app.band.ai
# Docs: https://docs.band.ai/getting-started/connect-remote-agent
BAND_ROOM_ID=your_band_chat_room_id_here

# Per-agent credentials (API key : agent UUID). Leave as placeholders to run
# the local in-memory Band simulator (offline mock mode).
BAND_AGENT1_API_KEY=your_agent1_api_key_here
BAND_AGENT1_ID=your_agent1_uuid_here
BAND_AGENT2_API_KEY=your_agent2_api_key_here
BAND_AGENT2_ID=your_agent2_uuid_here
BAND_AGENT3_API_KEY=your_agent3_api_key_here
BAND_AGENT3_ID=your_agent3_uuid_here
BAND_AGENT4_API_KEY=your_agent4_api_key_here
BAND_AGENT4_ID=your_agent4_uuid_here

# Optional: orchestrator/observer identity that posts the kickoff message and
# streams the room transcript into the UI coordination log.
BAND_ORCHESTRATOR_API_KEY=your_orchestrator_api_key_here
BAND_ORCHESTRATOR_ID=your_orchestrator_uuid_here

# ──────────────────────────────────────────────────────────────────────────
# Optional integrations (premium features)
# ──────────────────────────────────────────────────────────────────────────
# GitHub Issues export (Personal Access Token with `repo` scope).
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=owner/repo
# Jira export.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=SEC

# ──────────────────────────────────────────────────────────────────────────
# Pipeline Settings
# ──────────────────────────────────────────────────────────────────────────
PIPELINE_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO

# Set to "true" to disable PII masking before LLM calls (NOT recommended).
DISABLE_PII_MASKING=false
